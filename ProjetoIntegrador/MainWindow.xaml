        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Canvas>
        <Rectangle Height="56" Canvas.Left="185" Stroke="Black" Width="615" HorizontalAlignment="Center" VerticalAlignment="Top"/>
