<Window x:Class="ProjetoIntegrador.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProjetoIntegrador"
        mc:Ignorable="d"
        Title="WRV Control"
        Height="450"
        Width="800">

    <Canvas Background="White">

        <!-- MENU LATERAL -->
        <Rectangle Width="185"
                   Height="434"
                   Stroke="Black"/>

        <!-- TOPO -->
        <Rectangle Canvas.Left="185"
                   Width="615"
                   Height="56"
                   Stroke="Black"/>

        <!-- LOGO -->
        <Label Content="WRV"
               Canvas.Left="70"
               Canvas.Top="24"
               FontWeight="Bold"
               FontSize="18"/>

        <!-- BOTÕES MENU -->
        <Button Content="Estoque"
                Width="122"
                Height="29"
                Canvas.Left="32"
                Canvas.Top="61"/>

        <Button Content="Histórico"
                Width="122"
                Height="29"
                Canvas.Left="32"
                Canvas.Top="106"/>

        <Button Content="Financeiro"
                Width="122"
                Height="29"
                Canvas.Left="32"
                Canvas.Top="151"/>

        <Button Content="Sair"
                Width="122"
                Height="29"
                Canvas.Left="32"
                Canvas.Top="395"/>

        <!-- ================================================= -->
        <!-- LOGIN -->
        <!-- ================================================= -->

        <Canvas x:Name="Login"
                Visibility="Collapsed"
                Width="800"
                Height="434"
                Background="White">

            <Rectangle Width="277"
                       Height="234"
                       Canvas.Left="262"
                       Canvas.Top="100"
                       Stroke="Black"/>

            <Label Content="WRV"
                   Canvas.Left="340"
                   Canvas.Top="114"
                   FontWeight="Bold"
                   FontStyle="Italic"
                   FontSize="18"
                   Foreground="Blue"/>

            <Label Content="Control"
                   Canvas.Left="391"
                   Canvas.Top="114"
                   FontWeight="Bold"
                   FontSize="18"/>

            <Label Content="Usuário"
                   Canvas.Left="280"
                   Canvas.Top="183"/>

            <TextBox x:Name="User1"
                     Width="120"
                     Canvas.Left="340"
                     Canvas.Top="187"
                     TextChanged="TextBox_TextChanged"/>

            <Label Content="Senha"
                   Canvas.Left="280"
                   Canvas.Top="213"/>

            <TextBox x:Name="Senha1"
                     Width="120"
                     Canvas.Left="340"
                     Canvas.Top="217"
                     TextChanged="TextBox_TextChanged_1"/>

            <Button Content="Recuperar"
                    Width="70"
                    Canvas.Left="339"
                    Canvas.Top="249"
                    Background="#FF2B00FF"
                    Foreground="White"/>

            <Button Content="Acessar"
                    Width="70"
                    Canvas.Left="416"
                    Canvas.Top="249"
                    Background="#FF00BB14"
                    Foreground="White"/>

        </Canvas>

        <!-- ================================================= -->
        <!-- HISTÓRICO -->
        <!-- ================================================= -->

        <Canvas x:Name="HistDeVendas"
                Visibility="Visible"
                Width="615"
                Height="434"
                Canvas.Left="185">

            <TextBox Width="147"
                     Height="25"
                     Canvas.Left="458"
                     Canvas.Top="15"
                     Text="Pesquisar Produto"
                     TextChanged="TextBox_TextChanged"/>

            <Button x:Name="Comprovante"
                    Content="Comprovante"
                    Canvas.Left="458"
                    Canvas.Top="58"
                    Click="Button_Click"/>

            <DataGrid x:Name="Historico1"
                      Width="615"
                      Height="378"
                      Canvas.Top="55"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionChanged="Historico1_SelectionChanged">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Código"
                                        Binding="{Binding Codigo}"/>

                    <DataGridTextColumn Header="Qtd"
                                        Binding="{Binding Qtd}"/>

                    <DataGridTextColumn Header="Descrição"
                                        Binding="{Binding Descricao}"/>

                    <DataGridTextColumn Header="Valor"
                                        Binding="{Binding Valor}"/>

                    <DataGridTextColumn Header="Data"
                                        Binding="{Binding Data, StringFormat=dd/MM/yyyy}"/>

                    <DataGridTextColumn Header="Cliente"
                                        Binding="{Binding Cliente}"/>

                    <DataGridTextColumn Header="CPF"
                                        Binding="{Binding CPF}"/>

                </DataGrid.Columns>

            </DataGrid>

        </Canvas>

        <!-- ================================================= -->
        <!-- ESTOQUE -->
        <!-- ================================================= -->

        <Canvas x:Name="Estoque1"
                Visibility="Collapsed"
                Width="615"
                Height="434"
                Canvas.Left="185">

            <TextBox Width="147"
                     Height="25"
                     Canvas.Left="458"
                     Canvas.Top="15"
                     Text="Pesquisar Produto"
                     TextChanged="TextBox_TextChanged"/>

            <Button x:Name="Cad"
                    Content="Cadastrar"
                    Width="70"
                    Canvas.Left="19"
                    Canvas.Top="13"
                    Click="Cad_Click"/>

            <Button x:Name="Exc"
                    Content="Excluir"
                    Width="70"
                    Canvas.Left="97"
                    Canvas.Top="13"
                    Click="Exc_Click"/>

            <DataGrid x:Name="DGestoque"
                      Width="615"
                      Height="379"
                      Canvas.Top="55"
                      AutoGenerateColumns="False"
                      IsReadOnly="True">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Nome"
                                        Binding="{Binding nome}"/>

                    <DataGridTextColumn Header="Quantidade"
                                        Binding="{Binding qnt}"/>

                    <DataGridTextColumn Header="Código de Barras"
                                        Binding="{Binding codbarras}"/>

                </DataGrid.Columns>

            </DataGrid>

        </Canvas>

        <!-- ================================================= -->
        <!-- FINANCEIRO -->
        <!-- ================================================= -->

        <Canvas x:Name="Financeiro"
                Visibility="Collapsed"
                Width="615"
                Height="434"
                Canvas.Left="185"/>

    </Canvas>
</Window>