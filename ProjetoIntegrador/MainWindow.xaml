        <Button Content="Button" HorizontalAlignment="Left" Margin="32,154,0,0" VerticalAlignment="Top" Height="29" Width="122"/>
        <Button Content="Button" HorizontalAlignment="Left" VerticalAlignment="Top" Height="29" Width="122" Canvas.Left="32" Canvas.Top="395"/>
