<Window x:Class="ProjetoIntegrador.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProjetoIntegrador"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Canvas>
        <Rectangle Height="56" Canvas.Left="185" Stroke="Black" Width="615" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Button Content="Estoque" HorizontalAlignment="Left" Margin="32,61,0,0" VerticalAlignment="Top" Height="29" Width="122"/>
        <Button Content="His" HorizontalAlignment="Left" Margin="32,106,0,0" VerticalAlignment="Top" Height="29" Width="122"/>
        <Button Content="Button" HorizontalAlignment="Left" Margin="32,154,0,0" VerticalAlignment="Top" Height="29" Width="122"/>
        <Button Content="Button" HorizontalAlignment="Left" VerticalAlignment="Top" Height="29" Width="122" Canvas.Left="32" Canvas.Top="395"/>
        <Label Content="WRV CONTROL" HorizontalAlignment="Left" Margin="0,10,0,0" VerticalAlignment="Top" Height="46" Width="185"/>


        <Canvas x:Name="Login" Visibility="Visible" Width="800" HorizontalAlignment="Center" Height="434" VerticalAlignment="Center" Background="#FF3A3A3A">

            <Rectangle Height="234" Canvas.Left="262" Stroke="Black" Canvas.Top="100" Width="277" Fill="#FFC5C5C5">
                <Rectangle.Effect>
                    <DropShadowEffect/>
                </Rectangle.Effect>
            </Rectangle>
            <TextBox
    Height="22"
    Background="#2A2A2A"
    Foreground="White"
    BorderThickness="0"
    Padding="10" Canvas.Left="329" Canvas.Top="182" HorizontalAlignment="Center" VerticalAlignment="Center" Width="140"/>

            <TextBox
    Height="22"
    Background="#2A2A2A"
    Foreground="White"
    BorderThickness="0"
    Padding="10" Canvas.Left="329" Canvas.Top="215" HorizontalAlignment="Left" VerticalAlignment="Top" Width="140"/>

            <Label Content="Usuario:" Canvas.Left="280" Canvas.Top="178" HorizontalAlignment="Left" VerticalAlignment="Center" Foreground="Black" RenderTransformOrigin="0.793,0.464"/>
            <Label Content="Senha:" Canvas.Left="288" Canvas.Top="213" HorizontalAlignment="Left" VerticalAlignment="Center" Foreground="Black"/>

            <Button Style="{StaticResource RoundedButtonStyle}" Content="Acessar" Canvas.Left="400" Canvas.Top="245" HorizontalAlignment="Center" VerticalAlignment="Center" BorderBrush="Black" Background="#FF00BB14" Foreground="White" Height="24" Width="69" FontWeight="Bold" FontSize="15"/>

            <Label
    Content="WRV "
    FontFamily="Segoe UI"
    FontSize="28"
    FontWeight="Bold"
    Foreground="DarkBlue" Canvas.Left="312" Canvas.Top="111" HorizontalAlignment="Left" VerticalAlignment="Center">

                <Label.Effect>
                    <DropShadowEffect
            BlurRadius="12"
            ShadowDepth="2.5"
            Opacity="0.5"/>
                </Label.Effect>
            </Label>

            <Label
    Content="Control"
    FontFamily="Segoe UI"
    FontSize="28"
    FontWeight="Bold"
    Foreground="Black" Canvas.Left="380" Canvas.Top="111" HorizontalAlignment="Left" VerticalAlignment="Center">

                <Label.Effect>
                    <DropShadowEffect
            BlurRadius="10"
            ShadowDepth="2"
            Opacity="0.5"/>
                </Label.Effect>
            </Label>

            <Button Style="{StaticResource RoundedButtonStyle}" Content="Recuperar" Canvas.Left="326" Canvas.Top="245" HorizontalAlignment="Left" VerticalAlignment="Center" Foreground="White" BorderBrush="#FF0D0050" Background="#FF2B00FF" Height="24" Width="69" FontWeight="Bold" FontSize="13"/>
        </Canvas>

        <Canvas x:Name="Login1" Visibility="Collapsed" Width="800" HorizontalAlignment="Left" Height="434" VerticalAlignment="Center" Background="White"/>

        <Canvas x:Name="Estoque" Visibility="Visible" Width="615" HorizontalAlignment="Left" Height="434" VerticalAlignment="Center" Canvas.Left="185">
            <TextBox Canvas.Left="458" TextWrapping="Wrap" Text="Pesquisar Produto" Canvas.Top="15" Width="147" TextChanged="TextBox_TextChanged" Height="25" HorizontalAlignment="Left" VerticalAlignment="Center"/>

        </Canvas>

        <Canvas x:Name="Financeiro" Visibility="Collapsed" Width="610" HorizontalAlignment="Left" Height="434" VerticalAlignment="Center" Canvas.Left="190"/>

        <Canvas x:Name="HistDeVendas" Visibility="Collapsed" Width="610" HorizontalAlignment="Left" Height="434" VerticalAlignment="Center" Canvas.Left="190"/>
        <Rectangle HorizontalAlignment="Left" Height="432" Stroke="Black" VerticalAlignment="Top" Width="186" Canvas.Top="1"/>


    </Canvas>
</Window>